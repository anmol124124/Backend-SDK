# Copy to .env and fill in real values before deploying.
# cp .env.example .env

# App
APP_NAME=WebRTC SaaS Platform
APP_VERSION=0.1.0
DEBUG=false

# PostgreSQL — use strong passwords in production
POSTGRES_USER=webrtc
POSTGRES_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=webrtc_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# Set a password and configure redis with --requirepass in docker-compose
REDIS_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD

# RabbitMQ — change from the default guest/guest credentials
RABBITMQ_USER=webrtc
RABBITMQ_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_A_REAL_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# mediasoup SFU — internal service-to-service calls
# URL uses the Docker service name; not public-facing
MEDIASOUP_URL=http://mediasoup:3000
# Must match INTERNAL_SECRET in mediasoup-server/.env
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
MEDIASOUP_INTERNAL_SECRET=REPLACE_WITH_A_REAL_SECRET

# CORS — comma-separated list of allowed frontend origins
# Use * in production (security is handled by the domain allowlist on embed tokens)
CORS_ORIGINS=*

# Public URL of this backend — used to generate embed HTML.
# In production: set to your domain, e.g. https://api.yourplatform.com
# For local dev: http://localhost:8000
BACKEND_PUBLIC_URL=http://localhost:8000

# Public meeting token TTL (hours) — how long host/guest tokens stay valid
PUBLIC_HOST_TOKEN_TTL_HOURS=12
PUBLIC_GUEST_TOKEN_TTL_HOURS=12

# RSA key pair for public meeting tokens (RS256)
# Generate once and NEVER change after going live (active tokens will break).
# Generate command:
#   python3 -c "
#   from cryptography.hazmat.primitives.asymmetric import rsa
#   from cryptography.hazmat.primitives import serialization
#   import base64
#   key = rsa.generate_private_key(public_exponent=65537, key_size=2048)
#   priv = base64.b64encode(key.private_bytes(serialization.Encoding.PEM, serialization.PrivateFormat.PKCS8, serialization.NoEncryption())).decode()
#   pub  = base64.b64encode(key.public_key().public_bytes(serialization.Encoding.PEM, serialization.PublicFormat.SubjectPublicKeyInfo)).decode()
#   print('RSA_PRIVATE_KEY=' + priv)
#   print('RSA_PUBLIC_KEY='  + pub)
#   "
RSA_PRIVATE_KEY=REPLACE_WITH_BASE64_ENCODED_PEM_PRIVATE_KEY
RSA_PUBLIC_KEY=REPLACE_WITH_BASE64_ENCODED_PEM_PUBLIC_KEY
